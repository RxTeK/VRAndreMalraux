# Visual Studio 2015 user specific files
.vs/

# Binaries Unreal
Binaries/
**/Binaries/
Plugins/*/Binaries/
**/Plugins/**/Binaries/

# Optionnel si tu veux aussi ignorer les fichiers générés du plugin
**/Plugins/**/Intermediate/
**/Plugins/**/Saved/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

!MetaSimulation/
!MetaSimulation/**
!Plugins/MetaXRInteraction/
!Plugins/MetaXRInteraction/**
!Plugins/OculusInteractionSamples/
!Plugins/OculusInteractionSamples/**

# Within MetaXRPlatform, still ignore build folders
Plugins/MetaXR/Intermediate/
Plugins/MetaXRPlatform/Intermediate/
Plugins/MetaXRInteraction/Intermediate/
Plugins/OculusInteractionSamples/Intermediate/


# Within MetaXRPlatform, still ignore build folders
Plugins\MetaXR\Binaries**
Plugins/MetaXRPlatform/Binaries/
Plugins/MetaXRInteraction/Binaries/
Plugins/OculusInteractionSamples/Binaries/
